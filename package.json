{
  "name": "play-rough-rankings",
  "version": "1.0.0",
  "description": "Tournament leaderboard service for local card game tournaments",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "dev:localhost": "BETTER_AUTH_URL=http://localhost:3000 NEXT_PUBLIC_APP_URL=http://localhost:3000 next dev",
    "dev:ngrok": "BETTER_AUTH_URL=https://intersticed-pok-unfocused.ngrok-free.app NEXT_PUBLIC_APP_URL=https://intersticed-pok-unfocused.ngrok-free.app next dev",
    "dev:smart": "node scripts/start-dev.js",
    "build": "next build",
    "build:clean": "rm -rf .next tsconfig.tsbuildinfo node_modules/.cache && next build",
    "build:vercel": "rm -rf .next tsconfig.tsbuildinfo node_modules/.cache && npm run vercel-build",
    "build:strict": "npm run lint && npm run type-check && npm run build",
    "pre-deploy": "npm run build:strict && echo 'Build validation passed - ready for deployment'",
    "vercel-build": "prisma generate && next build",
    "type-check": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint .",
    "lint:errors": "eslint --quiet .",
    "test": "vitest --run",
    "test:unit": "vitest --run __tests__/unit",
    "test:integration": "vitest --run --config vitest.config.integration.ts __tests__/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:ci": "vitest --run --coverage",
    "test:ui": "vitest --ui",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:start": "docker-compose up -d postgres",
    "db:stop": "docker-compose stop postgres",
    "db:down": "docker-compose down",
    "db:reset": "docker-compose down -v && docker-compose up -d postgres && sleep 2 && npm run db:migrate",
    "db:setup": "npm run db:start && sleep 3 && npm run db:migrate",
    "script:create-missing-records": "npx tsx scripts/create-missing-records.ts",
    "script:create-missing-records:dry-run": "npx tsx scripts/create-missing-records.ts --dry-run",
    "script:create-tournament-test-data": "npx tsx scripts/create-tournament-test-data.ts",
    "script:cleanup-tournament-test-data": "npx tsx scripts/cleanup-tournament-test-data.ts",
    "script:reprocess-dlq": "npx tsx scripts/reprocess-dlq-messages.ts",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@aws-sdk/client-ses": "^3.936.0",
    "@aws-sdk/client-sns": "^3.936.0",
    "@aws-sdk/client-sqs": "^3.936.0",
    "@prisma/client": "^6.16.2",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-query": "^5.87.4",
    "@trpc/client": "^11.5.1",
    "@trpc/next": "^11.5.1",
    "@trpc/react-query": "^11.5.1",
    "@trpc/server": "^11.5.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.3",
    "@vercel/speed-insights": "^1.2.0",
    "better-auth": "^1.3.9",
    "csv-parser": "^3.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "next": "^15.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "resend": "^6.5.2",
    "sns-validator": "^0.3.5",
    "svix": "^1.81.0",
    "typescript": "^5.9.2",
    "zod": "^4.1.8",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.9",
    "@vitest/ui": "^4.0.9",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.8.28",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "9.35.0",
    "eslint-config-next": "15.5.6",
    "fast-check": "^4.3.0",
    "jsdom": "^27.2.0",
    "lucide-react": "^0.544.0",
    "msw": "^2.11.3",
    "postcss": "^8.5.6",
    "prisma": "^6.16.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "vitest": "^4.0.9"
  }
}
