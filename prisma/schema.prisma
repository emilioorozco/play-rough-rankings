generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String           @id @default(cuid())
  name                 String?
  firstName            String?
  lastName             String?
  email                String           @unique
  emailVerified        Boolean          @default(false)
  image                String?
  role                 String           @default("player")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  dateOfBirth          DateTime?
  userPreferences      UserPreferences?
  accounts             Account[]
  player               Player?
  sessions             Session[]
  organizedTournaments Tournament[]     @relation("TournamentOrganizer")
  sentInvitations      RoleInvitation[] @relation("RoleInvitations")

  @@map("user")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model RoleInvitation {
  id          String   @id @default(cuid())
  email       String
  role        String   // 'organizer' or 'admin'
  token       String   @unique
  invitedById String
  invitedBy   User     @relation("RoleInvitations", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@map("role_invitations")
}

model Game {
  id              String            @id @default(uuid())
  name            String            @unique
  shortName       String
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  decks           Deck[]
  playerGameStats PlayerGameStats[]
  tournaments     Tournament[]

  @@map("games")
}

model Player {
  id                String            @id @default(uuid())
  userId            String            @unique
  externalPlayerIds Json?
  metadata          Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  player1Matches    Match[]           @relation("Player1")
  player2Matches    Match[]           @relation("Player2")
  wonMatches        Match[]           @relation("MatchWinner")
  gameStats         PlayerGameStats[]
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournamentEntries TournamentEntry[]

  @@map("players")
}

model PlayerGameStats {
  id            String   @id @default(uuid())
  playerId      String
  gameId        String
  currentRating Int      @default(1200)
  seasonalStats Json
  bestFinish    Int?
  totalEarnings Float    @default(0)
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, gameId])
  @@map("player_game_stats")
}

model Store {
  id           String       @id @default(uuid())
  name         String
  address      String
  city         String
  state        String
  zipCode      String
  contactEmail String?
  website      String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tournaments  Tournament[]

  @@map("stores")
}

model Tournament {
  id                   String            @id @default(uuid())
  name                 String
  description          String?
  createdAt            DateTime          @default(now())
  date                 DateTime
  entryFee             Float?
  format               String
  gameId               String
  maxPlayers           Int?
  metadata             Json?
  organizerId          String
  prizePool            String?
  registrationDeadline DateTime?
  rules                String[]          @default([])
  storeId              String
  totalRounds          Int?
  tournamentLevel      String?
  tournamentStructure  String?
  updatedAt            DateTime          @updatedAt
  status               String            @default("UPCOMING")
  matches              Match[]
  entries              TournamentEntry[]
  game                 Game              @relation(fields: [gameId], references: [id])
  organizer            User              @relation("TournamentOrganizer", fields: [organizerId], references: [id])
  store                Store             @relation(fields: [storeId], references: [id])

  @@index([status, date])
  @@map("tournaments")
}

model Deck {
  id                String            @id @default(uuid())
  name              String
  archetype         String
  gameId            String
  format            String
  description       String?
  metadata          Json?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  game              Game              @relation(fields: [gameId], references: [id])
  tournamentEntries TournamentEntry[]

  @@unique([name, gameId, format])
  @@map("decks")
}

model TournamentEntry {
  id               String     @id @default(uuid())
  tournamentId     String
  playerId         String
  deckId           String?
  placement        Int?
  record           Json?
  seed             Int?
  registrationDate DateTime   @default(now())
  dropped          Boolean    @default(false)
  metadata         Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deck             Deck?      @relation(fields: [deckId], references: [id])
  player           Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournament       Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@index([tournamentId, dropped])
  @@map("tournament_entries")
}

model Match {
  id                String     @id @default(uuid())
  tournamentId      String
  player1Id         String
  player2Id         String
  winnerId          String?
  round             Int
  table             Int?
  status            String     @default("PENDING")
  player1Score      Int?
  player2Score      Int?
  scheduledTime     DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  playerSubmissions Json?
  player1           Player     @relation("Player1", fields: [player1Id], references: [id])
  player2           Player     @relation("Player2", fields: [player2Id], references: [id])
  tournament        Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  winner            Player?    @relation("MatchWinner", fields: [winnerId], references: [id])

  @@index([tournamentId, round, status])
  @@map("matches")
}

model UserPreferences {
  id                      String   @id
  userId                  String   @unique
  nameDisplayPreference   String   @default("DISPLAY_NAME")
  optInCommunications     Boolean  @default(false)
  optInTournamentUpdates  Boolean  @default(true)
  optInLeaderboardUpdates Boolean  @default(true)
  optInMarketing          Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  profileVisibility       String   @default("PUBLIC")
  subscribeToUpdates      Boolean  @default(false)
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UserPreferences_userId_fkey")

  @@map("UserPreferences")
}
