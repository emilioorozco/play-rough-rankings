# Environment variables for Play Rough Rankings Leaderboard Service
# Copy this file to .env and fill in your values

# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@localhost:port/database_name?schema=schema_name
DATABASE_URL="postgresql://username@localhost:5432/leaderboard?schema=public"

# Better Auth Configuration
# Generate a secure secret: openssl rand -hex 32
BETTER_AUTH_SECRET="your-32-character-hex-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# OAuth Provider Configuration

# Google OAuth (https://console.developers.google.com/)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# Apple OAuth (future implementation)
# APPLE_CLIENT_ID="your-apple-client-id"
# APPLE_CLIENT_SECRET="your-apple-client-secret"

# Application Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Development Settings
NODE_ENV="development"

# Optional: Prisma Logging
# Uncomment to enable query logging
# DEBUG="prisma:*"

# ============================================================================
# Email Configuration (Resend) - PREFERRED PROVIDER
# ============================================================================
# Resend is the preferred email provider for this application.
# It provides better deliverability, simpler setup, and built-in webhook support.
#
# DEVELOPMENT MODE:
# - If RESEND_API_KEY is not configured, emails will be logged to console
# - This allows testing email flows without Resend setup
# - Email content will be displayed in terminal output
#
# PRODUCTION MODE:
# - RESEND_API_KEY is REQUIRED for email delivery
# - RESEND_WEBHOOK_SECRET is REQUIRED for bounce/complaint handling
# - Emails will be sent via Resend with retry logic and delivery tracking
#
# Resend Setup Guide:
# 1. Create account at https://resend.com
# 2. Verify your domain in Resend dashboard
# 3. Generate API key from Resend dashboard
# 4. Set up webhook endpoint in Resend dashboard
# 5. Copy webhook signing secret from Resend dashboard
#
# Webhook URL: https://yourdomain.com/api/email/resend-webhook
#
# Benefits over AWS SES:
# - Simpler setup and configuration
# - Better developer experience
# - Built-in webhook support (no SNS/SQS setup needed)
# - Automatic bounce and complaint handling
# - Better deliverability rates
# ============================================================================

# Resend API Key for sending emails
# Generate from Resend dashboard: https://resend.com/api-keys
# Format: re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REQUIRED in production for email delivery
# PREFERRED: Set this to use Resend instead of AWS SES
RESEND_API_KEY=""

# Resend Webhook Signing Secret for webhook signature verification
# Get from Resend dashboard when setting up webhook endpoint
# Format: whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REQUIRED in production for bounce/complaint handling
# Used to verify webhook requests are authentic and untampered
RESEND_WEBHOOK_SECRET=""

# ============================================================================
# Email Configuration (AWS SES) - FALLBACK PROVIDER
# ============================================================================
# Email service for authentication flows (verification, password reset, invitations)
# 
# DEVELOPMENT MODE:
# - If AWS credentials are not configured, emails will be logged to console
# - This allows testing email flows without AWS SES setup
# - Email content will be displayed in terminal output
#
# PRODUCTION MODE:
# - All AWS variables below are REQUIRED for email delivery
# - Emails will be sent via AWS SES with retry logic and delivery tracking
# - Configure AWS SES in your AWS account before deploying to production
#
# AWS SES Setup Guide:
# 1. Create AWS account and navigate to SES console
# 2. Verify sender email address or domain
# 3. Configure DKIM signing for email authentication
# 4. Request production access (remove sandbox mode)
# 5. Set up bounce and complaint notifications (recommended)
# 6. Create IAM user with SES sending permissions
# 7. Generate access key and secret for the IAM user
#
# Required Permissions for IAM User:
# - ses:SendEmail
# - ses:SendRawEmail
#
# ============================================================================

# AWS Region for SES service
# Common regions: us-east-1, us-west-2, eu-west-1
# Choose region closest to your users for best performance
# Default: us-west-2
AWS_REGION="us-west-2"

# AWS Access Key ID for email services (SES, SNS, SQS)
# Generate from IAM user with email service permissions
# REQUIRED in production for email delivery and bounce/complaint handling
AWS_EMAIL_ACCESS_KEY_ID="your-aws-email-access-key-id"

# AWS Secret Access Key for email services (SES, SNS, SQS)
# Keep this secret secure - never commit to version control
# REQUIRED in production for email delivery and bounce/complaint handling
AWS_EMAIL_SECRET_ACCESS_KEY="your-aws-email-secret-access-key"

# Sender email address for all outgoing emails
# Used by both Resend and AWS SES providers
# Must be verified in Resend or AWS SES before use
# Format: noreply@yourdomain.com or support@yourdomain.com
# REQUIRED in production for email delivery
FROM_EMAIL="noreply@playroughrankings.com"

# Email Verification Configuration
# Controls whether email verification is required for new accounts
# Set to "true" to require email verification before account activation
# Set to "false" to allow immediate account access (not recommended for production)
# Default: true
REQUIRE_EMAIL_VERIFICATION="true"

# ============================================================================
# Email Rate Limiting
# ============================================================================
# Rate limits are enforced in-memory and reset on application restart
# For production with multiple instances, consider Redis-based rate limiting
#
# Current Limits (configured in code):
# - Email Verification: 3 requests per hour per email address
# - Password Reset: 3 requests per hour per email address
# - Role Invitations: 5 requests per 24 hours per admin
#
# Rate limits help prevent:
# - Email spam and abuse
# - Brute force attacks on verification/reset tokens
# - Resource exhaustion from excessive email sending
# ============================================================================

# ============================================================================
# Email Template Configuration
# ============================================================================
# Email templates use the following configuration:
# - Brand Colors: Primary (pink #E83F6F), Accent (gold #F1D460)
# - Responsive design for mobile and desktop email clients
# - Both HTML and plain text versions for compatibility
# - Consistent branding across all email types
#
# Email Types:
# 1. Email Verification - 24 hour token expiration
# 2. Password Reset - 1 hour token expiration
# 3. Role Invitations - 7 day token expiration
#
# All emails include:
# - Clear call-to-action buttons
# - Security information and expiration times
# - Plain text fallback for email clients without HTML support
# - Sender identification and branding
# ============================================================================

# ============================================================================
# AWS SES Production Checklist
# ============================================================================
# Before deploying to production, ensure:
#
# ☐ Sender email/domain verified in AWS SES
# ☐ DKIM signing configured for email authentication
# ☐ SPF and DMARC records configured for domain
# ☐ Production access requested and approved (removes sandbox mode)
# ☐ Bounce and complaint notifications configured
# ☐ CloudWatch monitoring enabled for email metrics
# ☐ IAM user created with minimal SES permissions
# ☐ Access keys generated and stored securely
# ☐ Environment variables configured in production environment
# ☐ Test emails sent successfully from production environment
#
# Monitoring and Maintenance:
# - Monitor bounce rates (should be < 5%)
# - Monitor complaint rates (should be < 0.1%)
# - Set up alerts for high failure rates
# - Review email delivery logs regularly
# - Clean up expired tokens from database periodically
# ============================================================================

# ============================================================================
# AWS SNS Configuration (Bounce and Complaint Handling)
# ============================================================================
# SNS topic for receiving bounce and complaint notifications from AWS SES
# This enables automatic suppression of problematic email addresses
#
# Setup Steps:
# 1. Create SNS topic in AWS console (e.g., "ses-bounces-complaints")
# 2. Configure SES to publish bounce/complaint notifications to SNS topic
# 3. Subscribe webhook endpoint to SNS topic
# 4. SNS will automatically confirm subscription via webhook
#
# Webhook URL: https://yourdomain.com/api/email/sns-webhook
#
# Benefits:
# - Automatic suppression of hard bounces (invalid email addresses)
# - Tracking of soft bounces with threshold-based suppression (3 in 30 days)
# - Immediate suppression of spam complaints (zero tolerance)
# - Maintains AWS SES reputation and compliance
# - Required for AWS SES production access approval
#
# OPTIONAL in development (bounce/complaint handling disabled without this)
# REQUIRED in production for AWS SES compliance and reputation management
# ============================================================================

# AWS SNS Topic ARN for bounce and complaint notifications
# Format: arn:aws:sns:region:account-id:topic-name
# Example: arn:aws:sns:us-west-2:123456789012:ses-bounces-complaints
# Leave empty in development to disable bounce/complaint handling
AWS_SNS_TOPIC_ARN=""

# Webhook URL for SNS notifications (for documentation purposes)
# This is the public URL where AWS SNS will send notifications
# Format: https://yourdomain.com/api/email/sns-webhook
# Note: This is automatically handled by the application, no configuration needed
# WEBHOOK_URL="https://playroughrankings.com/api/email/sns-webhook"

# AWS SQS Dead Letter Queue URL for failed bounce/complaint notifications
# Format: https://sqs.{region}.amazonaws.com/{account-id}/{queue-name}
# Example: https://sqs.us-west-2.amazonaws.com/123456789012/ses-bounces-complaints-dlq
# Used by scripts/reprocess-dlq-messages.ts to manually reprocess failed messages
# OPTIONAL - only needed if you want to reprocess failed DLQ messages
AWS_SQS_DLQ_URL=""

# ============================================================================
# Troubleshooting Email Issues
# ============================================================================
# 
# Emails not sending in development:
# - Check console output for email content (development mode logs to console)
# - Verify AWS credentials are NOT set (development should use console logging)
#
# Emails not sending in production:
# - Verify all AWS environment variables are set correctly
# - Check AWS SES console for sender verification status
# - Ensure AWS SES is out of sandbox mode
# - Check IAM user permissions for SES sending
# - Review application logs for error messages
# - Verify AWS region matches your SES configuration
#
# Rate limit errors:
# - Wait for rate limit window to expire (1 hour for verification/reset)
# - Check application logs for rate limit details
# - Consider implementing Redis-based rate limiting for production
#
# Token expiration errors:
# - Verification tokens expire after 24 hours
# - Password reset tokens expire after 1 hour
# - Role invitation tokens expire after 7 days
# - Users must request new tokens if expired
#
# Email delivery failures:
# - Check AWS SES bounce and complaint rates
# - Verify recipient email addresses are valid
# - Review AWS SES sending statistics in console
# - Check for AWS service outages or throttling
# - Ensure retry logic is functioning (automatic with 3 retries)
# ============================================================================
